{
    "configurations": [
        {
            "name": "RPi Pico (RP2040)",
            "includePath": [
                "${workspaceRoot}/src/**",
                "${workspaceFolder}/**",
                "C:/GdriveBG/Arduino/libraries/**",
                "C:/Users/${env:USERNAME}/AppData/Local/Arduino15/packages/rp2040/hardware/rp2040/**",
                "C:/Users/${env:USERNAME}/AppData/Local/Arduino15/packages/rp2040/tools/**",
                // "C:/Program Files/Arduino IDE/hardware/**",
                // "C:/Program Files/Arduino IDE/libraries/**"
                "C:/Users/${env:USERNAME}/AppData/Local/Arduino15/libraries/**"
            ],
            "defines": [
                "ARDUINO=10819",
                "ARDUINO_ARCH_RP2040",
                "ARDUINO_BOARD=Raspberry_Pi_Pico",
                "__RP2040__",
                "F_CPU=125000000L"
            ],
            // "compilerPath": "arm-none-eabi-gcc",
            "cStandard": "gnu17",
            "cppStandard": "gnu++17",
            "intelliSenseMode": "gcc-arm"
        }
    ],
    "version": 4
}